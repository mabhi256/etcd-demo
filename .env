REGISTRY=gcr.io/etcd-development/etcd
ETCD_VERSION=v3.6.0

TOKEN=my-etcd-token
CLUSTER_STATE=new
NAME_1=etcd-node-1
NAME_2=etcd-node-2
NAME_3=etcd-node-3
HOST_1=etcd1
HOST_2=etcd2
HOST_3=etcd3
CLUSTER=etcd-node-1=http://etcd1:2380,etcd-node-2=http://etcd2:2380,etcd-node-3=http://etcd3:2380
DATA_DIR=/var/lib/etcd
